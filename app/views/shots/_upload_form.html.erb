<div id="shot-upload-form" data-controller="upload" class="<%= "hidden" unless show_form %> my-4" data-panel-target="uploadForm">
  <div class="hidden" data-upload-target="error">
    <%= render Notification.new(type: "alert", heading: "Something went wrong") %>
  </div>
  <div class="px-4 sm:px-0">
    <div class="md:grid md:grid-cols-3 md:gap-6">
      <div class="md:col-span-1">
        <p class="text-neutral-600 dark:text-neutral-400">
          Upload one or more .shot, .json, or .csv files from Decent, Meticulous, Beanconqueror, Smart Espresso Profiler, Pressensor, or other compatible sources.
        </p>
      </div>
      <div class="mt-3 md:col-span-2 md:mt-0">
        <%= form_with(url: { action: :create }, multipart: true, data: { upload_target: "form" }) do |f| %>
          <div class="overflow-hidden rounded-md">
            <div class="p-4 bg-white inset-shadow-sm dark:bg-neutral-900">
              <div class="hidden justify-center py-10 px-6 rounded-md border-2 border-dashed border-neutral-300 dark:border-neutral-600" data-upload-target="loader">
                <%= inline_svg_tag "logo-loading.svg", class: "logo-loading mx-auto w-auto h-14 stroke-neutral-500 text-neutral-500 dark:text-neutral-400 dark:stroke-neutral-400" %>
              </div>
              <div class="flex justify-center py-9 px-6 rounded-md border-2 border-dashed border-neutral-300 dark:border-neutral-600" data-upload-target="dropArea">
                <div class="flex flex-col gap-y-1 text-center">
                  <svg class="mx-auto size-10 text-neutral-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  <div class="flex flex-wrap justify-center text-sm text-neutral-600 dark:text-neutral-300">
                    <label class="relative font-medium bg-white rounded-md cursor-pointer focus-within:ring-2 focus-within:ring-offset-2 focus-within:outline-none text-oxford-blue-600 dark:bg-neutral-900 dark:text-oxford-blue-400 dark:hover:text-oxford-blue-600 focus-within:ring-oxford-blue-500 hover:text-oxford-blue-500" for="files">
                      <span>Select your files</span>
                      <%= file_field_tag "files", multiple: true, name: "files[]", class: "hidden", data: { upload_target: "files" } %>
                    </label>
                    <p class="pl-1">or drag and drop them</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
        <% if Current.user.meticulous_enabled %>
        <div class="mt-3" data-controller="meticulous-import"
             data-meticulous-import-submit-url-value="<%= shots_path %>"
             data-meticulous-import-machine-url-value="<%= Current.user.meticulous_url %>">
          <div class="flex gap-2 items-center">
            <div class="h-px grow bg-neutral-200 dark:bg-neutral-700"></div>
            <span class="text-xs tracking-wide uppercase text-neutral-400">or</span>
            <div class="h-px grow bg-neutral-200 dark:bg-neutral-700"></div>
          </div>
          <button type="button" data-action="meticulous-import#openDialog"
                  class="flex justify-center items-center py-2 px-3 mt-3 w-full whitespace-nowrap button-white">
            Import from Meticulous
          </button>
          <p class="mt-2 text-sm text-neutral-500" data-meticulous-import-target="status"></p>

          <dialog data-meticulous-import-target="dialog"
                  class="p-0 m-auto w-full max-w-md rounded-lg shadow-xl backdrop:bg-black/50 bg-white dark:bg-neutral-800">
            <div class="p-4">
              <div class="flex justify-between items-center mb-2">
                <h3 class="font-medium text-neutral-900 dark:text-neutral-100">Import shots from Meticulous</h3>
                <button type="button" data-action="meticulous-import#closeDialog" aria-label="Close"
                        class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200">✕</button>
              </div>
              <p class="mb-2 text-sm text-neutral-500">Select the shots you want to import.</p>
              <div data-meticulous-import-target="loading" class="hidden py-10 text-sm text-center text-neutral-500">
                <svg class="inline animate-spin size-6 text-neutral-400" viewBox="0 0 24 24" fill="none">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v4a4 4 0 0 0-4 4H4z"></path>
                </svg>
                <p class="mt-2" data-meticulous-import-target="loadingLabel">Loading recent shots…</p>
              </div>
              <div data-meticulous-import-target="list"
                   class="overflow-y-auto max-h-80 divide-y divide-neutral-200 dark:divide-neutral-700"></div>

              <template data-meticulous-import-target="rowTemplate">
                <label class="flex gap-3 items-center py-2 px-1 cursor-pointer hover:bg-neutral-50 dark:hover:bg-neutral-900">
                  <input type="checkbox" class="standard-checkbox size-4 cursor-pointer" data-meticulous-import-target="shotCheckbox">
                  <span class="grow text-sm truncate text-neutral-900 dark:text-neutral-100" data-row="name"></span>
                  <span class="shrink-0 mr-2 text-xs text-neutral-500" data-row="time"></span>
                </label>
              </template>

              <p class="mt-2 text-sm" data-meticulous-import-target="dialogStatus"></p>
              <div class="flex gap-2 justify-end mt-4">
                <button type="button" data-action="meticulous-import#closeDialog" class="py-2 px-3 button-white">Cancel</button>
                <button type="button" data-action="meticulous-import#importSelected" data-meticulous-import-target="importButton"
                        class="py-2 px-3 button-terracotta">Import selected</button>
              </div>
            </div>
          </dialog>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
